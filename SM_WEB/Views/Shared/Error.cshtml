@{
    var autenticado = Context.Session.GetString("Autenticado");
}

@if (autenticado == "1")
    Layout = "_Layout";
else
    Layout = "_LayoutExterno";    

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card border-0 rounded-4">
            <div class="card-body text-center" style="padding: 5rem 4rem;">

                <i class="bi bi-exclamation-triangle-fill text-danger" style="font-size: 5rem;"></i>

                <h3 class="fw-bold text-muted mb-2">Se presentó un inconveniente técnico</h3>
                <p class="text-muted mb-4">
                    Por favor, comuníquese con el administrador del sistema.
                </p>

                @if (autenticado == "1")
                {
                    <div class="d-flex justify-content-center mt-4">
                        <a asp-controller="Home" asp-action="Principal" class="btn btn-primary">
                            <i class="bi bi-house-fill me-1"></i> Ir al inicio
                        </a>
                    </div>
                }
                else
                {
                    <div class="d-flex justify-content-center mt-4">
                        <a asp-controller="Home" asp-action="Index" class="btn btn-primary">
                            <i class="bi bi-house-fill me-1"></i> Ir al inicio
                        </a>
                    </div>
                }               

            </div>
        </div>
    </div>
</div>
