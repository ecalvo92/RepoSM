<div class="row h-100">
    <div class="col-lg-6 col-12">
        <div id="auth-left">
            <div class="auth-logo">
                <a asp-action="Index" asp-controller="Home"><img src="~/images/logo-fidelitas.png" alt="Logo"></a>
            </div>
            <h1 class="auth-title">Recuperar Acceso</h1>

            <form>
                <div class="form-group position-relative has-icon-left mb-4">
                    <input type="email" class="form-control form-control-xl" placeholder="Correo Electrónico">
                    <div class="form-control-icon">
                        <i class="bi bi-envelope"></i>
                    </div>
                </div>
                <button class="btn btn-primary btn-block btn-lg shadow-lg mt-1">Procesar</button>
            </form>
            <div class="text-center mt-5 text-lg fs-4">
                <p class='text-gray-600'>
                    ¿Recuerda su contraseña? <a asp-action="Index" asp-controller="Home" class="font-bold">
                    Iniciar Sesión
                </a>
            </p>
        </div>
    </div>
</div>
<div class="col-lg-6 d-none d-lg-block">
    <div id="auth-right">
    </div>
</div>
</div>